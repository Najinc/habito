# Configuration Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=habito_ads
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Configuration embedding (Qwen3-Embedding-8B from Hugging Face)
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIM=384

# Configuration reranking (Qwen3-Reranker-4B from Hugging Face)
RERANKING_MODEL=Qwen/Qwen3-Reranker-4B

# Performance mode
# false: fast mode on CPU (fallback hash/vector order), true: force HF models on CPU (very slow)
ALLOW_HF_ON_CPU=false

# Groq chatbot advisor
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Configuration recherche
SEARCH_LIMIT=10

# Configuration ingestion Leboncoin
LBC_TEXT=appartement
LBC_CITY=Paris
LBC_LAT=48.8566
LBC_LNG=2.3522
LBC_RADIUS=10000
LBC_PAGE=1
LBC_LIMIT=35
LBC_PRICE_MIN=500
LBC_PRICE_MAX=1500

# Mode progressif (multi-pages)
LBC_PROGRESSIVE=false
LBC_MAX_PAGES=1
LBC_STATE_FILE=./.ingest_state.json

# Multi-villes (format: Ville:Latitude:Longitude séparés par ;)
LBC_LOCATIONS=Paris:48.8566:2.3522;Lille:50.6292:3.0573;Reims:49.2583:4.0317
